<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head', { title }) %></head>
<body class="page-impact">
<%- include('../partials/header', { activePage }) %>

<main class="impact-main">
  <section class="impact-hero">
    <div class="container">
      <div class="impact-hero-card">
        <div class="impact-hero-photo" role="img" aria-label="A vibrant Zambian marketplace at sunrise with entrepreneurs at work"></div>
        <div class="impact-hero-copy">
          <span class="impact-pill">Maturity &amp; Growth</span>
          <h1>Our Impact</h1>
          <p class="impact-lead">
            Building the foundations of Zambia's future economy through structured support.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="impact-intro">
    <div class="container impact-intro-inner">
      <h2>Creating Connected Businesses</h2>
      <p>
        Moovex isn't just about practical support—it's about architecture. We transform fragmented ideas
        into organized, connected, and capable businesses that drive sustainable employment across Zambia.
      </p>
    </div>
  </section>

  <section class="impact-metrics" aria-labelledby="impact-metrics-heading">
    <div class="container">
      <p id="impact-metrics-heading" class="impact-metrics-note">
        Impact figures shown as reporting targets/placeholders pending verification.
      </p>
      <div class="impact-metrics-bento">
        <div class="impact-metrics-row">
          <article class="impact-metric-card impact-metric-gradient">
            <div class="impact-metric-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M10 2h4a2 2 0 012 2v2h4v16H4V6h4V4a2 2 0 012-2zm2 4V4h-2v2h2z"></path></svg>
            </div>
            <strong class="impact-metric-value">10+</strong>
            <span class="impact-metric-label">Companies<br>Supported</span>
          </article>

          <article class="impact-metric-card impact-metric-gradient">
            <div class="impact-metric-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M16 11c1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 3-1.34 3-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5C15 14.17 10.33 13 8 13zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"></path></svg>
            </div>
            <strong class="impact-metric-value">450+</strong>
            <span class="impact-metric-label">Entrepreneurs<br>Advised</span>
          </article>
        </div>

        <article class="impact-feature-card">
          <div class="impact-feature-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"></path></svg>
          </div>
          <strong class="impact-feature-value">$2.4M</strong>
          <p class="impact-feature-label">In Direct Capital Catalyzed for Local SMBs</p>
          <div class="impact-progress" aria-hidden="true">
            <span class="impact-progress-fill"></span>
          </div>
          <div class="impact-progress-labels">
            <span>Target: $2.8M</span>
            <span>85% Achieved</span>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="impact-stories">
    <div class="container">
      <header class="impact-stories-heading">
        <h2>Voices of Growth</h2>
        <p>Real stories from the Moovex ecosystem.</p>
      </header>

      <article class="impact-story-card">
        <div
          class="impact-story-photo impact-story-scene"
          role="img"
          aria-label="A confident young Zambian woman entrepreneur smiling in her modern technology office"
        ></div>
        <div class="impact-story-body">
          <p class="impact-story-spotlight">
            <svg class="impact-story-star" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"></path></svg>
            Success Spotlight
          </p>
          <h3>AgriTech Solutions Ltd.</h3>
          <p class="impact-story-quote">
            &ldquo;Moovex helped us transition from a local farm to a national digital distributor. Their
            structural advice was the missing piece of our puzzle.&rdquo;
          </p>
          <div class="impact-story-author">
            <div class="impact-story-avatar">
              <img
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuBOHhGoUbt1mhcz1GJLoLiXFcx_Zc65tK7y_frr1sxLMZ96-zBK2moyK7EPVpCyHjOa4kyI06QnowxZBfgQvWarK7ue93OxMEapO47ceD98NHhDhkjWeVM7-8E7VtkmnnIE7_wjfvpufyed6ctkPUd3fDgHq6PjnT5Bs9L6w4HUUdT9DPH_Mrk-e2DcU1QZ-uUg75g95AyP32wM8VGe9-pa6WoMEGeYe558SQLlTbuZhB0Y4ZU3781UZ1rdTCUGyQr5JOe60GGYDVM"
                alt="Chanda Mwewa"
                width="48"
                height="48"
                loading="lazy"
              />
            </div>
            <div>
              <p class="impact-story-name">Chanda Mwewa</p>
              <p class="impact-story-role">Founder &amp; CEO</p>
            </div>
          </div>
        </div>
      </article>
    </div>
  </section>

  <section class="impact-action">
    <div class="container">
      <div class="impact-action-card">
        <h2>Your Support in Action</h2>
        <ul class="impact-action-list">
          <li>
            <span class="impact-action-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z"></path></svg>
            </span>
            <div>
              <h4>Specialized Training</h4>
              <p>Sustaining technical mentorship for emerging business leaders across the Moovex ecosystem.</p>
            </div>
          </li>
          <li>
            <span class="impact-action-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M4 6h18V4H4a2 2 0 00-2 2v11a2 2 0 002 2h14v-2H4V6zm13 6H9v2h8v-2zm0-4H9v2h8V8z"></path></svg>
            </span>
            <div>
              <h4>Digital Infrastructure</h4>
              <p>Providing digital tools and essential business systems to streamline operations.</p>
            </div>
          </li>
          <li>
            <span class="impact-action-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20 6h-4V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V8a2 2 0 00-2-2zM10 4h4v2h-4V4zm6 13H8v-2h8v2z"></path></svg>
            </span>
            <div>
              <h4>Job Creation</h4>
              <p>Supporting jobs and opportunity creation through entrepreneurship programs and local services.</p>
            </div>
          </li>
        </ul>
        <a href="/partner" class="impact-btn">Partner With Us</a>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
