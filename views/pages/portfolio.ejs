<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head', { title }) %></head>
<body class="page-portfolio">
<%- include('../partials/header', { activePage }) %>

<main class="port-main">
  <header class="port-hero">
    <div class="container port-hero-inner">
      <h1>Our Portfolio</h1>
      <p class="port-lead">
        Driving Zambia's economic growth through diverse and sustainable local entrepreneurship.
      </p>
    </div>
  </header>

  <section class="port-companies">
    <div class="container port-grid">
      <article class="port-bento port-soft-shadow" id="chomaya">
        <div class="port-photo port-photo-chomaya" role="img" aria-label="Transport and microfuel operations">
          <div class="port-photo-icon port-photo-icon-orange" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M19.77 7.23l.01-.01-3.72-3.72L15 4.56l2.11 2.11c-.94.36-1.61 1.26-1.61 2.33 0 1.38 1.12 2.5 2.5 2.5.36 0 .69-.08 1-.21v7.21c0 .55-.45 1-1 1s-1-.45-1-1V14c0-1.1-.9-2-2-2h-1V5c0-1.1-.9-2-2-2H6c-1.1 0-2 .9-2 2v7H3c-1.1 0-2 .9-2 2v3c0 .55.45 1 1 1s1-.45 1-1v-1h12v1c0 .55.45 1 1 1s1-.45 1-1v-3c0-.34-.08-.65-.21-.94l3.23-3.23zM6 5h6v7H6V5z"></path></svg>
          </div>
          <span class="port-photo-label">Microfuel &amp; Transport</span>
        </div>
        <div class="port-card-body">
          <div class="port-card-head">
            <div>
              <h2>Chomaya</h2>
              <p class="port-card-category">Energy &amp; Logistics</p>
            </div>
            <span class="port-card-badge">Moovex Ecosystem</span>
          </div>
          <p class="port-card-desc">
            Microfuel and fuel-management solutions for PSV drivers, taxis, buses, and transport operators.
            Revolutionizing energy distribution for small-scale transport industries.
          </p>
          <div class="port-card-tags">
            <span>#FuelManagement</span>
            <span>#TransportLogistics</span>
            <span>#PSVSupport</span>
          </div>
          <div class="port-card-footer">
            <div class="port-card-impact">
              <span class="port-card-impact-label">Impact Area:</span>
              <strong>Transport Efficiency</strong>
            </div>
            <a href="/ecosystem" class="port-btn">
              Learn More
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8-8-8z"></path></svg>
            </a>
          </div>
        </div>
      </article>

      <article class="port-bento port-soft-shadow" id="getpro">
        <div class="port-photo port-photo-getpro" role="img" aria-label="Call center and digital agency workspace">
          <div class="port-photo-icon port-photo-icon-teal" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3zm7 11v2a7 7 0 01-14 0v-2H3v2a9 9 0 0018 0v-2h-2z"></path></svg>
          </div>
          <span class="port-photo-label">Digital &amp; Call Center</span>
        </div>
        <div class="port-card-body">
          <div class="port-card-head">
            <div>
              <h2>GetPro</h2>
              <p class="port-card-category">Tech &amp; Creative</p>
            </div>
            <span class="port-card-badge">Moovex Ecosystem</span>
          </div>
          <p class="port-card-desc">
            Call center and digital agency helping clients improve customer service, business processes, websites,
            apps, Facebook, Instagram, and TikTok. The bridge between local talent and global markets.
          </p>
          <div class="port-card-tags">
            <span>#CallCenter</span>
            <span>#WebDev</span>
            <span>#SocialMediaMarketing</span>
          </div>
          <div class="port-card-footer">
            <div class="port-card-impact">
              <span class="port-card-impact-label">Impact Area:</span>
              <strong>Digital Transformation</strong>
            </div>
            <a href="/ecosystem" class="port-btn">
              Learn More
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8-8-8z"></path></svg>
            </a>
          </div>
        </div>
      </article>

      <article class="port-bento port-soft-shadow" id="facha">
        <div class="port-photo port-photo-facha" role="img" aria-label="Retail and e-banking services">
          <div class="port-photo-icon port-photo-icon-orange" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M4 10v10h16V10H4zm2 2h12v6H6v-6zm2-6h8v2H8V6zm2-4h4v2h-4V2z"></path></svg>
          </div>
          <span class="port-photo-label">Retail &amp; E-Banking</span>
        </div>
        <div class="port-card-body">
          <div class="port-card-head">
            <div>
              <h2>Facha</h2>
              <p class="port-card-category">Stationery &amp; Digital Access</p>
            </div>
            <span class="port-card-badge">Moovex Ecosystem</span>
          </div>
          <p class="port-card-desc">
            Stationery, internet café, wholesale drinks, and e-banking services for Airtel, MTN, Zamtel, Zanaco,
            FNB, and Indo-Zambia Bank. Empowering communities through integrated retail services.
          </p>
          <div class="port-card-tags">
            <span>#EBanking</span>
            <span>#Retail</span>
            <span>#DigitalAccess</span>
          </div>
          <div class="port-card-footer">
            <div class="port-card-impact">
              <span class="port-card-impact-label">Impact Area:</span>
              <strong>Financial Inclusion</strong>
            </div>
            <a href="/ecosystem" class="port-btn">
              Learn More
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8-8-8z"></path></svg>
            </a>
          </div>
        </div>
      </article>

      <article class="port-bento port-soft-shadow" id="netra">
        <div class="port-photo port-photo-netra" role="img" aria-label="Commercial property and shopping complex management">
          <div class="port-photo-icon port-photo-icon-teal" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 7V3H2v18h20V7H12zm-2 12H4v-2h6v2zm0-4H4v-2h6v2zm0-4H4V9h6v2zm8 8h-6v-2h6v2zm0-4h-6v-2h6v2zm0-4h-6V9h6v2z"></path></svg>
          </div>
          <span class="port-photo-label">Property Management</span>
        </div>
        <div class="port-card-body">
          <div class="port-card-head">
            <div>
              <h2>Netra</h2>
              <p class="port-card-category">Real Estate</p>
            </div>
            <span class="port-card-badge">Moovex Ecosystem</span>
          </div>
          <p class="port-card-desc">
            Commercial property management for shopping complexes to improve operations, tenant performance,
            customer traffic, and revenue. Strategic management of high-value local assets.
          </p>
          <div class="port-card-tags">
            <span>#PropertyOps</span>
            <span>#TenantSupport</span>
            <span>#RevenueGrowth</span>
          </div>
          <div class="port-card-footer">
            <div class="port-card-impact">
              <span class="port-card-impact-label">Impact Area:</span>
              <strong>Commercial Growth</strong>
            </div>
            <a href="/ecosystem" class="port-btn">
              Learn More
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8-8-8z"></path></svg>
            </a>
          </div>
        </div>
      </article>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
