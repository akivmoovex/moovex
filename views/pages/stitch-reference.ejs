<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head', { title }) %>
</head>
<body>
<%- include('../partials/header', { activePage }) %>

<main>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Design Reference</p>
      <h1>Stitch Mobile Screens</h1>
      <p class="hero-text">
        Exported Stitch mobile screens for visual reference while adjusting the live website.
      </p>
    </div>
  </section>

  <section class="section soft">
    <div class="container">
      <div class="stitch-grid">
        <article class="stitch-card">
          <h3>Home</h3>
          <img src="/images/stitch/01-home-mobile/01-home-mobile.png" alt="Home mobile Stitch screen" loading="lazy">
        </article>

        <article class="stitch-card">
          <h3>About</h3>
          <img src="/images/stitch/02-about-mobile/02-about-mobile.png" alt="About mobile Stitch screen" loading="lazy">
        </article>

        <article class="stitch-card">
          <h3>Ecosystem</h3>
          <img src="/images/stitch/03-ecosystem-mobile/03-ecosystem-mobile.png" alt="Ecosystem mobile Stitch screen" loading="lazy">
        </article>

        <article class="stitch-card">
          <h3>Portfolio</h3>
          <img src="/images/stitch/04-portfolio-mobile/04-portfolio-mobile.png" alt="Portfolio mobile Stitch screen" loading="lazy">
        </article>

        <article class="stitch-card">
          <h3>Impact</h3>
          <img src="/images/stitch/05-impact-mobile/05-impact-mobile.png" alt="Impact mobile Stitch screen" loading="lazy">
        </article>

        <article class="stitch-card">
          <h3>Partner / Donate</h3>
          <img src="/images/stitch/06-partner-donate-mobile/screen.png" alt="Partner / Donate mobile Stitch screen" loading="lazy">
        </article>

        <article class="stitch-card">
          <h3>Contact</h3>
          <img src="/images/stitch/07-contact-mobile/07-contact-mobile.png" alt="Contact mobile Stitch screen" loading="lazy">
        </article>

        <article class="stitch-card">
          <h3>Updates</h3>
          <img src="/images/stitch/08-updates-mobile/08-updates-mobile.png" alt="Updates mobile Stitch screen" loading="lazy">
        </article>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
