<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head', { title }) %></head>
<body class="page-updates">
<%- include('../partials/header', { activePage }) %>

<main class="updates-main">
  <div class="container updates-container">
    <header class="updates-header">
      <h1>Latest Updates</h1>
      <p class="updates-lead">Stay informed about our growing ecosystem and the practical impact we're building across Zambia.</p>
    </header>

    <div class="updates-categories" aria-label="Update categories (filtering coming soon)">
      <span class="updates-pill updates-pill-active">All Updates</span>
      <span class="updates-pill updates-pill-draft" title="Draft category">Entrepreneurship</span>
      <span class="updates-pill updates-pill-draft" title="Draft category">Company Updates</span>
      <span class="updates-pill updates-pill-draft" title="Draft category">Impact Stories</span>
      <span class="updates-pill updates-pill-draft" title="Draft category">Partnerships</span>
    </div>

    <div class="updates-feed">
      <article class="updates-card updates-card-featured updates-soft-shadow">
        <div class="updates-card-photo">
          <div class="updates-photo-scene" aria-hidden="true">
            <span class="updates-scene-window"></span>
            <span class="updates-scene-table"></span>
            <span class="updates-scene-figure updates-scene-figure-a"></span>
            <span class="updates-scene-figure updates-scene-figure-b"></span>
          </div>
          <span class="updates-badge updates-badge-featured">Featured</span>
        </div>
        <div class="updates-card-body">
          <p class="updates-meta">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 4h-1V2h-2v2H8V2H6v2H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V6a2 2 0 00-2-2zm0 16H5V10h14v10zM5 8V6h14v2H5z"></path></svg>
            <span>Coming soon</span>
            <span class="updates-meta-sep" aria-hidden="true">•</span>
            <span>Entrepreneurship</span>
          </p>
          <h2>Building Practical Entrepreneurship Across Zambia</h2>
          <p>
            Future update on connected business growth, mentorship, and how the Moovex ecosystem supports
            entrepreneurs through transport, digital services, retail, e-banking, and property management.
          </p>
          <span class="updates-link updates-link-muted" aria-disabled="true">
            Read More
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8-8-8z"></path></svg>
          </span>
        </div>
      </article>

      <div class="updates-card-wrap">
        <article class="updates-card updates-card-dim">
          <p class="updates-meta">
            <span>Coming soon</span>
            <span class="updates-meta-sep" aria-hidden="true">•</span>
            <span>Impact Stories</span>
          </p>
          <h2>Jobs, Services &amp; Community Impact</h2>
          <p>
            Future update on jobs created, e-banking access expanded, and practical outcomes from Moovex
            portfolio companies serving local communities.
          </p>
        </article>
        <div class="updates-soon-overlay" aria-hidden="true">
          <div class="updates-soon-badge">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M6 2v6h.01L6 8.01 10 12l-4 4 .01.01H6V22h12v-5.99h-.01L18 16l-4-4 4-3.99-.01-.01H18V2H6zm10 14.5V20H8v-3.5l4-4 4 4zm-4-7l-4-4V4h8v3.5l-4 4z"></path></svg>
            <span>Coming Soon</span>
          </div>
        </div>
      </div>

      <article class="updates-card updates-soft-shadow">
        <div class="updates-card-top">
          <span class="updates-badge">Draft category</span>
          <span class="updates-meta-date">Coming soon</span>
        </div>
        <h2>Portfolio Company News</h2>
        <p>
          Future update for announcements from Chomaya, GetPro, Facha, Netra, and future Moovex ecosystem
          partners as they grow and serve customers across Zambia.
        </p>
        <span class="updates-link updates-link-muted" aria-disabled="true">
          Read More
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8-8-8z"></path></svg>
        </span>
      </article>

      <div class="updates-card-wrap">
        <article class="updates-card updates-card-dim">
          <p class="updates-meta">
            <span>Future update</span>
            <span class="updates-meta-sep" aria-hidden="true">•</span>
            <span>Partnerships</span>
          </p>
          <h2>Partner &amp; Donor Collaborations</h2>
          <p>
            Placeholder for partnership announcements, donor updates, and collaboration news supporting
            practical entrepreneurship in Zambia.
          </p>
        </article>
        <div class="updates-soon-overlay" aria-hidden="true">
          <div class="updates-soon-badge">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M18 8h-1V6a5 5 0 00-10 0v2H6a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V10a2 2 0 00-2-2zM9 6a3 3 0 016 0v2H9V6zm9 14H6V10h12v10zm-6-3a2 2 0 100-4 2 2 0 000 4z"></path></svg>
            <span>Future Update</span>
          </div>
        </div>
      </div>

      <article class="updates-card updates-soft-shadow">
        <div class="updates-card-top">
          <span class="updates-badge">Draft category</span>
          <span class="updates-meta-date">Coming soon</span>
        </div>
        <h2>State of Local Entrepreneurship</h2>
        <p>
          Placeholder for future reports and insights on trends, opportunities, and practical entrepreneurship
          across Zambian markets.
        </p>
        <span class="updates-link updates-link-muted" aria-disabled="true">
          Download Report
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"></path></svg>
        </span>
      </article>
    </div>

    <div class="updates-load-more">
      <button type="button" class="updates-load-btn" disabled aria-disabled="true" title="Future update">View Past Updates</button>
      <p class="updates-load-note">Future update — archive coming soon</p>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
